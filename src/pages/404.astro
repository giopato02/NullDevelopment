---
import Base from '../layouts/Base.astro';

const title = '404 — value is null · NullDevelopment';
const description = 'The page you were looking for could not be found.';
---

<Base title={title} description={description} path="/404" noindex={true}>
  <section class="notfound wrap">
    <div>
      <div class="code">404</div>
      <h1>value is <span class="mono">null</span></h1>
      <p>
        This page resolved to nothing — which, around here, is usually where things
        <em>start</em>, not how they end. Let's get you back to something real.
      </p>
      <div class="cta-row" style="justify-content:center">
        <a class="btn btn-primary" href="/">Back to home</a>
        <a class="btn btn-ghost" href="/#apps">Browse the apps</a>
      </div>
    </div>
  </section>
</Base>
