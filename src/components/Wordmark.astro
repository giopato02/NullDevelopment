---
// Reusable "NullDevelopment" wordmark.
// "Null" renders in JetBrains Mono (the brand accent); "Development" in the
// body sans. Size is controlled by the parent context (header / hero / footer),
// so this component stays purely structural.
interface Props {
  /** Render inside an <a href="/"> (used in the header brand). */
  href?: string;
  /** Accessible label when used as a link. */
  ariaLabel?: string;
}
const { href, ariaLabel } = Astro.props;
const Tag = href ? 'a' : 'span';
---

<Tag
  class:list={['wordmark', { brand: !!href }]}
  {...href ? { href, 'aria-label': ariaLabel ?? 'NullDevelopment — home' } : {}}
>
  {
    href && (
      <img class="brand-mark" src="/odev-logo.png" alt="" width="59" height="34" />
    )
  }<span class="label"><span class="wm-null">Null</span><span class="wm-rest">Development</span></span>
</Tag>
